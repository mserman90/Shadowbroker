# ShadowBroker — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# =============================================================================
# KEYLESS MODE (default) — No API keys required!
# All core features work without any keys:
#   Aircraft tracking (adsb.lol — free, no key)
#   Military flights (adsb.lol military endpoint — free, no key)
#   Satellites (CelesTrak + SGP4 — free, no key)
#   Earthquakes (USGS — free, no key)
#   Geopolitics/Conflicts (GDELT — free, no key)
#   Ukraine frontline (DeepState — free, no key)
#   CCTV cameras (TfL/London, Austin TX, NYC DOT — all free, no key)
#   Fires (NASA FIRMS — free, no key)
#   Space weather (NOAA SWPC — free, no key)
#   Internet outages (IODA Georgia Tech — free, no key)
#   KiwiSDR receivers (free, no key)
#   GPS jamming detection (derived from ADS-B data)
#   Day/Night cycle, Earthquakes, News feeds — all free
# =============================================================================

# --- OPTIONAL: Enhances data quality / adds extra sources ---

# OpenSky Network OAuth2 — Higher rate limits for flight coverage in
# Africa, South America, and Asia (without this, adsb.lol is still used globally)
# Get free credentials at: https://opensky-network.org/
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# AIS Stream (aisstream.io) — Real-time maritime vessel tracking via WebSocket
# Without this key, the vessel/ship layer will be DISABLED (shows empty).
# Get a FREE key at: https://aisstream.io/ (free tier available)
AIS_API_KEY=

# LTA Singapore traffic cameras — adds ~90 Singapore road cameras
# Get a free key at: https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
# (Leave blank to skip — other CCTV sources still work without it)
LTA_ACCOUNT_KEY=

# --- Backend networking ---
# Override the backend URL the frontend uses (leave blank for auto-detect)
# NEXT_PUBLIC_API_URL=http://192.168.1.50:8000
